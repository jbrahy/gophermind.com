# GopherMind configuration — example template.
#
# Copy this file to `.env` (which is gitignored) and edit as needed:
#
#     cp .env.example .env
#
# The app auto-loads `.env` from the working directory at startup. Any value
# already exported in your real environment WINS over the file — `.env` only
# fills gaps. Every variable below is optional; the shown value is the built-in
# default. Uncomment and change only what you need. Command-line flags (see
# `gophermind --help`) override both.
#
# Secrets (API keys, TLS keys) belong ONLY in your local `.env` — never commit
# real values.

# ── Endpoint (OpenAI-compatible) ─────────────────────────────────────────────
# Base URL of the completions endpoint. Required — there is NO built-in default;
# set it here, pick a provider profile below, or use the first-run setup wizard.
#GOPHERMIND_BASE_URL=http://localhost:8080
# API key / bearer token. Leave empty when reaching the endpoint over a VPN.
#GOPHERMIND_API_KEY=
# Model name. Empty => auto-discovered from the endpoint's /v1/models at startup.
#GOPHERMIND_MODEL=
# Comma-separated models tried in order after MODEL on a fallback-eligible failure.
#GOPHERMIND_FALLBACK_MODELS=

# ── Behavior ─────────────────────────────────────────────────────────────────
# Working root the agent operates within. Empty => current working directory.
#GOPHERMIND_ROOT=
# Directory holding the global config .env written by the setup wizard. Empty =>
# the OS user-config dir (e.g. ~/Library/Application Support/gophermind on macOS).
#GOPHERMIND_CONFIG_DIR=
# Tool-approval mode: `ask` (prompt before each action) or `auto` (no prompts).
#GOPHERMIND_APPROVAL=ask
# Max agent iterations per task (>= 1).
#GOPHERMIND_MAX_ITER=25

# ── Timeouts ─────────────────────────────────────────────────────────────────
# HTTP timeout for the one-shot startup calls (model discovery/listing,
# capability probe), in seconds.
#GOPHERMIND_HTTP_TIMEOUT_S=300
# Per-attempt timeout for LLM completion requests. Separate from the HTTP
# timeout above so a slow model gets a generous budget without stalling
# startup. Bare number = seconds; units also accepted ("15m"). Unset =>
# inherit GOPHERMIND_HTTP_TIMEOUT_S.
#GOPHERMIND_LLM_TIMEOUT=300
# Per-command (shell tool) timeout, in seconds.
#GOPHERMIND_CMD_TIMEOUT_S=120

# ── Retry (bounded exponential backoff) ──────────────────────────────────────
# Total attempts per request (1 disables retries; min 1).
#GOPHERMIND_MAX_ATTEMPTS=3
# First backoff interval, in milliseconds (grows exponentially with jitter).
#GOPHERMIND_RETRY_BASE_DELAY_MS=250

# ── Sampling ─────────────────────────────────────────────────────────────────
# Temperature, range [0,2]. 0 is deterministic. Adjustable at runtime via /temp.
#GOPHERMIND_TEMPERATURE=0
# top_p nucleus sampling, range (0,1]. Unset => omitted from the request entirely.
#GOPHERMIND_TOP_P=

# ── Cost meter (per-1,000-token prices, USD) ─────────────────────────────────
# Both default to 0, so the running cost meter reports $0.00 until configured.
#GOPHERMIND_PRICE_INPUT_PER_1K=0
#GOPHERMIND_PRICE_OUTPUT_PER_1K=0

# ── TLS for internal endpoints ───────────────────────────────────────────────
# Skip TLS verification (self-signed endpoints). INSECURE — prefer the CA/mTLS
# options below. Truthy values: 1, true, yes, on.
#GOPHERMIND_INSECURE_TLS=false
# Client-certificate (mutual TLS) auth. CERT and KEY are required TOGETHER.
#GOPHERMIND_CLIENT_CERT=/path/to/client-cert.pem
#GOPHERMIND_CLIENT_KEY=/path/to/client-key.pem
# Private CA to trust for the server (appended to system roots; verification ON).
#GOPHERMIND_CA_CERT=/path/to/ca.pem

# ── Response cache (non-streaming completions) ───────────────────────────────
# Off by default: caching writes prompt/response content to disk. Truthy: 1/true/yes/on.
#GOPHERMIND_CACHE_ENABLED=false
# Cache directory. Empty => <OS user cache>/gophermind/cache, else .gophermind/cache.
#GOPHERMIND_CACHE_DIR=
# Cache entry time-to-live, as a Go duration (e.g. 24h, 30m).
#GOPHERMIND_CACHE_TTL=24h

# ── Transcript ───────────────────────────────────────────────────────────────
# Path for a JSONL dump of the full message history at session end (also
# --transcript). File is created 0600 / parent dir 0700. Unset => no transcript.
#GOPHERMIND_TRANSCRIPT=

# ── Provider profiles ────────────────────────────────────────────────────────
# Select a named backend with GOPHERMIND_PROFILE (or --profile). Built-ins:
# `local-llama`, `openai`, `anthropic-proxy`. Empty => the legacy single endpoint
# configured above.
#GOPHERMIND_PROFILE=
#
# Per-profile overrides use the pattern GOPHERMIND_PROFILE_<NAME>_<FIELD>, where
# <NAME> is the upper-cased profile name with '-' replaced by '_'. Fields:
# _BASE_URL, _MODEL, _API_KEY, _TIMEOUT (seconds). A custom (non-built-in)
# profile is recognized only once its _BASE_URL is set. Examples:
#GOPHERMIND_PROFILE_OPENAI_API_KEY=
#GOPHERMIND_PROFILE_OPENAI_MODEL=gpt-4o-mini
#GOPHERMIND_PROFILE_ANTHROPIC_PROXY_BASE_URL=http://127.0.0.1:8082/v1
